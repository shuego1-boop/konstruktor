{
  "name": "player",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5174",
    "build": "tsc && vite build",
    "cap:sync": "cap sync",
    "cap:android": "cap run android",
    "cap:build:android": "bun run build && cap sync android && cd android && ./gradlew assembleRelease",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/network": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "@konstruktor/quiz-engine": "workspace:*",
    "@konstruktor/shared": "workspace:*",
    "@konstruktor/ui": "workspace:*",
    "canvas-confetti": "^1.9.4",
    "framer-motion": "^12.0.0",
    "howler": "^2.2.4",
    "idb": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.13.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/howler": "^2.2.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.7",
    "happy-dom": "^20.8.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.0.7"
  }
}
