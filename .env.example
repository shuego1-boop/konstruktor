# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (Digital Ocean Managed Postgres) ────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/konstruktor

# ─── Auth (Better Auth) ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-32-char-random-string
BETTER_AUTH_URL=http://localhost:3000

# ─── Digital Ocean Spaces (S3-compatible file storage) ───────────────────────
DO_SPACES_KEY=your-spaces-access-key
DO_SPACES_SECRET=your-spaces-secret-key
DO_SPACES_BUCKET=konstruktor-assets
DO_SPACES_REGION=ams3
DO_SPACES_ENDPOINT=https://ams3.digitaloceanspaces.com
DO_SPACES_CDN_URL=https://konstruktor-assets.ams3.cdn.digitaloceanspaces.com

# ─── Frontend (injected at Vite build time) ───────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_CDN_URL=https://konstruktor-assets.ams3.cdn.digitaloceanspaces.com
